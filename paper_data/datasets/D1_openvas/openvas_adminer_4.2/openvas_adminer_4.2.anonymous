      <nvt oid="1.3.6.1.4.1.25623.1.0.111038">
        <type>nvt</type>
        <name>Web Application Scanning Consolidation / Info Reporting</name>
        <family>Web application abuses</family>
        <cvss_base>0.0</cvss_base>
        <severities score="0.0">
          <severity type="cvss_base_v2">
            <origin />
