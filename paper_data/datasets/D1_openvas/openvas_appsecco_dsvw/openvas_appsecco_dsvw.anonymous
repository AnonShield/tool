          <ref type="url" id="https://github.com/python/cpython/issues/103800" />
          <ref type="cert-bund" id="WID-SEC-2025-0225" />
          <ref type="cert-bund" id="WID-SEC-2024-0885" />
          <ref type="cert-bund" id="WID-SEC-2023-1561" />
          <ref type="dfn-cert" id="DFN-CERT-2024-1003" />
        </refs>
      </nvt>
