    <result id="62cbe624-eb93-45ed-89e2-a3ffcfa4a0aa">
      <name>Python 'zipfile' Module Vulnerability (Oct 2025) - Linux</name>
      <modification_time>2026-01-26T18:18:11Z</modification_time>
      <comment />
      <creation_time>2026-01-26T18:18:11Z</creation_time>
      <detection>
        <result id="04e821c9-c0cd-47f8-82f9-19d397b07047">
          <details>
            <detail>
              <name>product</name>
              <value>cpe:/a:python:python:2.7.13</value>
            </detail>
            <detail>
              <name>location</name>
              <value>8000/tcp</value>
            </detail>
            <detail>
              <name>source_oid</name>
              <value>1.3.6.1.4.1.25623.1.0.112857</value>
            </detail>
            <detail>
              <name>source_name</name>
              <value>Python Detection Consolidation</value>
            </detail>
