        <type>nvt</type>
        <name>PHP &lt; 5.6.31, 7.0.x &lt; 7.0.21, 7.1.x &lt; 7.1.7 Multiple Vulnerabilities (Jul 2017) - Linux</name>
        <family>Web application abuses</family>
