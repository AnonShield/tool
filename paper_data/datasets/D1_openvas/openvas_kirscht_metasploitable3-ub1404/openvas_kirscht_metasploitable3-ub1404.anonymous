    <result id="f3e0665b-b18c-4448-8ce1-c9ff31f2d5c2">
      <name>Samba AD DC Principal Modification Vulnerability (CVE-2018-16860)</name>
      <modification_time>2026-01-26T18:19:37Z</modification_time>
      <comment />
      <creation_time>2026-01-26T18:19:37Z</creation_time>
      <detection>
        <result id="32fd92f6-f14d-4cae-9eb7-85dfb8a1d224">
          <details>
            <detail>
              <name>product</name>
              <value>cpe:/a:samba:samba:4.3.11</value>
            </detail>
            <detail>
              <name>location</name>
              <value>445/tcp</value>
            </detail>
