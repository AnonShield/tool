      <name>Samba Information Disclosure Vulnerability (CVE-2021-44141)</name>
      <modification_time>2026-01-26T18:19:37Z</modification_time>
      <comment />
      <creation_time>2026-01-26T18:19:37Z</creation_time>
      <detection>
        <result id="32fd92f6-f14d-4cae-9eb7-85dfb8a1d224">
