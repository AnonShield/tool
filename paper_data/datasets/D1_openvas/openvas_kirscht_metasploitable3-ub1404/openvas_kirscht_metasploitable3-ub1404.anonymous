      <nvt oid="1.3.6.1.4.1.25623.1.0.805651">
        <type>nvt</type>
        <name>PHP &lt; 5.4.39, 5.5.x &lt; 5.5.23, 5.6.x &lt; 5.6.7 Multiple Vulnerabilities - Linux</name>
        <family>Web application abuses</family>
        <cvss_base>7.5</cvss_base>
        <severities score="7.5">
          <severity type="cvss_base_v2">
            <origin />
            <date>2015-06-16T13:15:49Z</date>
