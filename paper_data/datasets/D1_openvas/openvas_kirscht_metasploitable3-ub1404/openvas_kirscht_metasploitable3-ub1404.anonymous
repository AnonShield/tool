    <result id="c98c189a-3383-42e0-9d6d-75854ed589ac">
      <name>Prefix Truncation Attacks in SSH Specification (Terrapin Attack)</name>
      <modification_time>2026-01-26T18:19:37Z</modification_time>
      <comment />
      <creation_time>2026-01-26T18:19:37Z</creation_time>
      <detection>
        <result id="924895a9-f3ba-49ba-a089-18c588e7de46">
          <details>
            <detail>
              <name>product</name>
              <value>cpe:/a:ietf:secure_shell_protocol</value>
            </detail>
