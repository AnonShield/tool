      <nvt oid="1.3.6.1.4.1.25623.1.0.104597">
        <type>nvt</type>
        <name>Apache HTTP Server 2.4.0 - 2.4.55 HTTP Request Smuggling Vulnerability - Linux</name>
        <family>Web Servers</family>
        <cvss_base>9.8</cvss_base>
        <severities score="9.8">
          <severity type="cvss_base_v3">
            <origin>NVD</origin>
