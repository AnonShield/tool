        <type>nvt</type>
        <name>phpMyAdmin &lt; 4.9.5, 5.x &lt; 5.0.2 Multiple SQL Injection Vulnerabilities (PMASA-2020-2, PMASA-2020-3, PMASA-2020-4) - Linux</name>
