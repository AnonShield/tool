      <port>3306/tcp</port>
      <nvt oid="1.3.6.1.4.1.25623.1.0.801355">
        <type>nvt</type>
        <name>MySQL Multiple Vulnerabilities</name>
        <family>Databases</family>
        <cvss_base>6.5</cvss_base>
        <severities score="6.5">
          <severity type="cvss_base_v2">
            <origin />
            <date>2010-06-11T12:27:58Z</date>
