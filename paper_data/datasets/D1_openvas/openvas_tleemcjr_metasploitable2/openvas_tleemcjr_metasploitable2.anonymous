      <port>22/tcp</port>
      <nvt oid="1.3.6.1.4.1.25623.1.0.809154">
        <type>nvt</type>
        <name>OpenSSH &lt; 7.3 DoS and User Enumeration Vulnerabilities - Linux</name>
        <family>Denial of Service</family>
