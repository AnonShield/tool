      <nvt oid="1.3.6.1.4.1.25623.1.0.8103256">
        <type>nvt</type>
        <name>OpenSSH &lt; 7.4 Multiple Vulnerabilities (Jan 2017) - Linux</name>
        <family>General</family>
        <cvss_base>7.8</cvss_base>
        <severities score="7.8">
          <severity type="cvss_base_v3">
            <origin>NVD</origin>
            <date>2018-09-11T10:29:00Z</date>
            <score>7.8</score>
