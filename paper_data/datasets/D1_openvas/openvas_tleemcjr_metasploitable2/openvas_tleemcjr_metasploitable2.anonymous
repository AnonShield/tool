        <type>nvt</type>
        <name>phpMyAdmin 2.11.x &lt; 2.11.9.4 / 3.0.x &lt; 3.1.3 Multiple Vulnerabilities</name>
        <family>Web application abuses</family>
        <cvss_base>9.8</cvss_base>
        <severities score="9.8">
          <severity type="cvss_base_v3">
            <origin>NVD</origin>
