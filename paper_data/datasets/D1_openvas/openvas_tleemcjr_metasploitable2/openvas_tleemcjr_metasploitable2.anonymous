      <name>Weak Key Exchange (KEX) Algorithm(s) Supported (SSH)</name>
      <modification_time>2026-01-26T12:26:07Z</modification_time>
      <comment />
      <creation_time>2026-01-26T12:26:07Z</creation_time>
      <detection>
        <result id="15b9f7b5-8848-4dc4-860d-0d515dd2b029">
          <details>
            <detail>
              <name>product</name>
              <value>cpe:/a:ietf:secure_shell_protocol</value>
            </detail>
            <detail>
              <name>location</name>
