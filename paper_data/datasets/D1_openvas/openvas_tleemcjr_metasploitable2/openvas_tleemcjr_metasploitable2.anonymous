    <result id="3b04be2b-1e24-40c4-ab26-7943f46d7af5">
      <name>Samba 3.0.6 &lt;= 3.0.23d Multiple Vulnerabilities</name>
      <modification_time>2026-01-26T12:19:36Z</modification_time>
      <comment />
      <creation_time>2026-01-26T12:19:36Z</creation_time>
      <detection>
        <result id="595f3604-ef85-42ba-9d92-dcc0211cdfcc">
          <details>
            <detail>
              <name>product</name>
              <value>cpe:/a:samba:samba:3.0.20</value>
