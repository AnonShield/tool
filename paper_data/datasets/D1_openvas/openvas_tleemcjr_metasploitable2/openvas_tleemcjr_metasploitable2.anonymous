      <name>Samba Information Disclosure Vulnerability (CVE-2021-44141)</name>
      <modification_time>2026-01-26T12:25:45Z</modification_time>
      <comment />
      <creation_time>2026-01-26T12:25:45Z</creation_time>
      <detection>
        <result id="595f3604-ef85-42ba-9d92-dcc0211cdfcc">
          <details>
            <detail>
