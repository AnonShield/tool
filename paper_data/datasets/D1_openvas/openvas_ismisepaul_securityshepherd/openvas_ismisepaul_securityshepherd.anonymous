    <result id="aa5be4aa-2031-422a-9009-bbcb0f997914">
      <name>Diffie-Hellman Ephemeral Key Exchange DoS Vulnerability (SSL/TLS, D(HE)ater)</name>
      <modification_time>2026-01-26T03:38:15Z</modification_time>
      <comment />
      <creation_time>2026-01-26T03:38:15Z</creation_time>
      <detection>
        <result id="382fd5c9-378b-4332-bfb3-0fc7b70d6915">
          <details>
