          <ref type="url" id="https://www.researchgate.net/profile/Anton-Stiglic-2/publication/2401745_Security_Issues_in_the_Diffie-Hellman_Key_Agreement_Protocol" />
          <ref type="url" id="https://github.com/Balasys/dheater" />
