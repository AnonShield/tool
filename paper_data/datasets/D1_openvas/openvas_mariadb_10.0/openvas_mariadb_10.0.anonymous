        <type />
      </qod>
      <original_threat>Low</original_threat>
      <original_severity>2.6</original_severity>
      <compliance>undefined</compliance>
    </result>
    <result id="0ecd89cc-aef2-4074-a843-b96ef87f1b95">
      <name>ICMP Timestamp Reply Information Disclosure</name>
      <modification_time>2026-01-26T08:38:44Z</modification_time>
      <comment />
      <creation_time>2026-01-26T08:38:44Z</creation_time>
