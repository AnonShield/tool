      <nvt oid="1.3.6.1.4.1.25623.1.0.151888">
        <type>nvt</type>
        <name>MongoDB Certificate Validation Vulnerability (SERVER-72839) - Linux</name>
        <family>Databases</family>
        <cvss_base>9.8</cvss_base>
        <severities score="9.8">
          <severity type="cvss_base_v3">
            <origin>NVD</origin>
            <date>2025-03-11T16:56:35Z</date>
            <score>9.8</score>
            <value>CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:H</value>
          </severity>
