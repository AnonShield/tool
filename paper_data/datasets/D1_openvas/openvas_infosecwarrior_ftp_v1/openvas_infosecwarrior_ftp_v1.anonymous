    <result id="c8a0cdc8-7e07-441f-afc0-c272886ab83e">
      <name>Apache HTTP Server 2.4.7 - 2.4.65 Authentication Bypass Vulnerability - Linux</name>
      <modification_time>2026-01-26T09:00:01Z</modification_time>
      <comment />
      <creation_time>2026-01-26T09:00:01Z</creation_time>
      <detection>
        <result id="1fc66b2d-01e4-4f02-8b59-4c308fd81545">
          <details>
            <detail>
              <name>product</name>
              <value>cpe:/a:apache:http_server:2.4.59</value>
            </detail>
            <detail>
              <name>location</name>
              <value>80/tcp</value>
            </detail>
            <detail>
              <name>source_oid</name>
              <value>1.3.6.1.4.1.25623.1.0.117232</value>
