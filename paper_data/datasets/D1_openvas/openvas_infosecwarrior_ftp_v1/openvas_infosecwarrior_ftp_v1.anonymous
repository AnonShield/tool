      <nvt oid="1.3.6.1.4.1.25623.1.0.117696">
        <type>nvt</type>
        <name>OpenSSH 6.2 &lt;= 8.7 Privilege Escalation Vulnerability</name>
        <family>Privilege escalation</family>
        <cvss_base>7.0</cvss_base>
        <severities score="7.0">
          <severity type="cvss_base_v3">
            <origin>NVD</origin>
