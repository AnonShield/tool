      </detection>
      <host>127.0.0.1<asset asset_id="13a9ba38-ceca-44f2-8867-4601dc05d807" /><hostname>host1.example.com</hostname></host>
      <port>8080/tcp</port>
      <nvt oid="1.3.6.1.4.1.25623.1.0.153234">
        <type>nvt</type>
        <name>Eclipse Jetty URI Parsing Vulnerability (GHSA-qh8g-58pp-2wxh) - Linux</name>
        <family>Web Servers</family>
        <cvss_base>5.3</cvss_base>
        <severities score="5.3">
          <severity type="cvss_base_v3">
            <origin>NVD</origin>
            <date>2024-11-08T21:15:57Z</date>
            <score>5.3</score>
            <value>CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:L/A:N</value>
          </severity>
        </severities>
        <tags>cvss_base_vector=CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:N/I:L/A:N|summary=Eclipse Jetty is prone to an URI parsing vulnerability.|insight=Eclipse Jetty includes a utility class, HttpURI, for URI/URL
  parsing.

  The HttpURI class does insufficient validation on the authority segment of a URI. However the
  behaviour of HttpURI differs from the common browsers in how it handles a URI that would be
  considered invalid if fully validated against the RRC. Specifically HttpURI and the browser may
  differ on the value of the host extracted from an invalid URI and thus a combination of Jetty and
  a vulnerable browser may be vulnerable to a open redirect attack or to a SSRF attack if the URI
  is used after passing validation checks.|affected=Eclipse Jetty version 7.0.0 through 12.0.11.|impact=|solution=Update to version 12.0.12 or later.|vuldetect=Checks if a vulnerable version is present on the target host.|solution_type=VendorFix</tags>
        <solution type="VendorFix">Update to version 12.0.12 or later.</solution>
        <refs>
          <ref type="cve" id="CVE-2024-6763" />
          <ref type="url" id="https://github.com/jetty/jetty.project/security/advisories/GHSA-qh8g-58pp-2wxh" />
          <ref type="url" id="https://www.eclipse.org//lists/jetty-announce/msg00194.html" />
          <ref type="cert-bund" id="WID-SEC-2025-1572" />
          <ref type="cert-bund" id="WID-SEC-2025-1565" />
          <ref type="cert-bund" id="WID-SEC-2025-0823" />
          <ref type="cert-bund" id="WID-SEC-2025-0138" />
          <ref type="cert-bund" id="WID-SEC-2024-3176" />
          <ref type="dfn-cert" id="DFN-CERT-2025-2102" />
          <ref type="dfn-cert" id="DFN-CERT-2025-1898" />
          <ref type="dfn-cert" id="DFN-CERT-2025-1748" />
          <ref type="dfn-cert" id="DFN-CERT-2025-1395" />
          <ref type="dfn-cert" id="DFN-CERT-2025-0835" />
          <ref type="dfn-cert" id="DFN-CERT-2025-0167" />
        </refs>
      </nvt>
