      <host>127.0.0.1<asset asset_id="13a9ba38-ceca-44f2-8867-4601dc05d807" /><hostname>host1.example.com</hostname></host>
      <port>8080/tcp</port>
      <nvt oid="1.3.6.1.4.1.25623.1.0.151003">
        <type>nvt</type>
        <name>Eclipse Jetty CgiServlet Vulnerability (GHSA-3gh6-v5v9-6v9j) - Linux</name>
        <family>Web Servers</family>
        <cvss_base>3.1</cvss_base>
        <severities score="3.1">
          <severity type="cvss_base_v3">
            <origin>NVD</origin>
            <date>2025-05-27T21:20:37Z</date>
            <score>3.1</score>
            <value>CVSS:3.1/AV:N/AC:H/PR:L/UI:N/S:U/C:N/I:L/A:N</value>
          </severity>
        </severities>
        <tags>cvss_base_vector=CVSS:3.1/AV:N/AC:H/PR:L/UI:N/S:U/C:N/I:L/A:N|summary=Eclipse Jetty is prone to a vulnerability in the CgiServlet.|insight=Users of the CgiServlet with a very specific command structure
  may have the wrong command executed. If a user sends a request to a
  org.eclipse.jetty.servlets.CGI Servlet for a binary with a space in its name, the servlet will
  escape the command by wrapping it in quotation marks. This wrapped command, plus an optional
  command prefix, will then be executed through a call to Runtime.exec. If the original binary name
  provided by the user contains a quotation mark followed by a space, the resulting command line
  will contain multiple tokens instead of one.|affected=Eclipse Jetty version 9.0.0 through 9.4.51, 10.0.0 through
  10.0.15 and 11.0.0 through 11.0.15.|impact=|solution=Update to version 9.4.52, 10.0.16, 11.0.16 or later.|vuldetect=Checks if a vulnerable version is present on the target host.|solution_type=VendorFix</tags>
        <solution type="VendorFix">Update to version 9.4.52, 10.0.16, 11.0.16 or later.</solution>
        <refs>
