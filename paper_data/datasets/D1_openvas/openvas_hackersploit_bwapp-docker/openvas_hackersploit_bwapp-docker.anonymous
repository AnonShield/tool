      <nvt oid="1.3.6.1.4.1.25623.1.0.805638">
        <type>nvt</type>
        <name>Apache HTTP Server Multiple Vulnerabilities (May 2015)</name>
        <family>Web Servers</family>
        <cvss_base>6.8</cvss_base>
        <severities score="6.8">
          <severity type="cvss_base_v2">
            <origin />
