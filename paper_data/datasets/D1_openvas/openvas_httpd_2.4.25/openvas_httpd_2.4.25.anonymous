    <result id="32de4cae-3128-4b7d-880b-8dd7279d64e9">
      <name>Apache HTTP Server OPTIONS Memory Leak Vulnerability (Optionsbleed) - Version Check</name>
      <modification_time>2026-01-26T12:03:36Z</modification_time>
      <comment />
      <creation_time>2026-01-26T12:03:36Z</creation_time>
      <detection>
        <result id="cfdff420-6c0e-4165-a8c1-a9da10c62092">
          <details>
