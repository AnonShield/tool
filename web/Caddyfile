# Caddyfile for AnonShield Production
# Handles automatic SSL and reverse proxying

{
    # Global options
    # Automatic HTTPS is enabled by default
}

anonshield.org, www.anonshield.org {
    # Reverse proxy for Backend API
    handle /api/* {
        reverse_proxy backend:8000
    }

    # Reverse proxy for Frontend
    handle {
        reverse_proxy frontend:3000
    }

    # Content Security Policy and Security Headers
    header {
        # Security headers
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        
        # CSP (Restrictive, adjust if needed for your static assets)
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self';"
    }

    # Log configuration
    log {
        output file /var/log/caddy/access.log
    }
}
