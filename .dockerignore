# =============================================================================
# Docker Ignore File - AnonLFI
# =============================================================================
# This file excludes unnecessary files from the Docker build context,
# reducing build time and image size.
# =============================================================================

# -----------------------------------------------------------------------------
# Version Control
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# Virtual Environments & Dependencies
# -----------------------------------------------------------------------------
.venv
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# Build & Distribution Artifacts
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# Testing & Quality
# -----------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.tox/
.nox/
.coverage
coverage.xml
*.cover
htmlcov/
.hypothesis/

# -----------------------------------------------------------------------------
# Runtime Data (should be mounted as volumes)
# -----------------------------------------------------------------------------
db/
db_pytest/
logs/
output/
models/

# -----------------------------------------------------------------------------
# Local Data & Samples
# -----------------------------------------------------------------------------
ignore/
data/
*.log
*.tmp
*.bak

# Sample/test data directories
anonimizados*/
dry_run/

# -----------------------------------------------------------------------------
# Documentation (not needed in runtime)
# -----------------------------------------------------------------------------
docs/
*.md
!README.md

# -----------------------------------------------------------------------------
# Configuration (sensitive or local)
# -----------------------------------------------------------------------------
.env
.env.*
*.local
secrets/

# -----------------------------------------------------------------------------
# OS-specific
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# CI/CD
# -----------------------------------------------------------------------------
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile
.circleci/

# -----------------------------------------------------------------------------
# Docker (avoid recursive includes)
# -----------------------------------------------------------------------------
Dockerfile*
docker-compose*.yml
.dockerignore

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
Makefile
*.sh
!docker-entrypoint.sh
LICENSE
CHANGELOG*
CONTRIBUTING*
