# =============================================================================
# AnonLFI - Environment Variables
# =============================================================================
# Copy this file to .env and customize as needed
# =============================================================================

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Secret key for generating anonymization hashes (REQUIRED for production)
ANON_SECRET_KEY=change-me-to-a-secure-random-string

# -----------------------------------------------------------------------------
# Ollama Configuration
# -----------------------------------------------------------------------------
# Base URL for Ollama service
# Default: http://localhost:11434 (native) or http://ollama:11434 (docker)
OLLAMA_BASE_URL=http://ollama:11434

# Default model for SLM features
OLLAMA_MODEL=llama3

# -----------------------------------------------------------------------------
# Lazy Loading Configuration
# -----------------------------------------------------------------------------
# Enable lazy loading of models (1=enabled, 0=disabled)
ANON_LAZY_LOADING=1

# Preload specific models at startup (comma-separated)
# Examples:
#   ANON_PRELOAD=en_core_web_lg
#   ANON_PRELOAD=en_core_web_lg,pt_core_news_lg
#   ANON_PRELOAD=spacy:en_core_web_lg,transformer:Davlan/xlm-roberta-base-ner-hrl
ANON_PRELOAD=

# -----------------------------------------------------------------------------
# Data Directories
# -----------------------------------------------------------------------------
# Host directory to mount as /data in the container
DATA_DIR=./data

# -----------------------------------------------------------------------------
# LLM Provider (future use)
# -----------------------------------------------------------------------------
LLM_PROVIDER=ollama
